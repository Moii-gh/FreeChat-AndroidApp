<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:paddingHorizontal="12dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_circle_outline"
            android:clickable="true"
            android:contentDescription="@string/content_desc_back"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/widget_config_title"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnSave"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_circle_outline"
            android:clickable="true"
            android:contentDescription="@string/button_save"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ic_check"
            app:tint="#FFFFFF" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp">

        <TextView
            android:id="@+id/tvWidgetConfigDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_config_description"
            android:textColor="#8E8E93"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/widgetConfigPreviewPanel"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_attachment_widget_panel"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingVertical="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/attachment_widget_input_height"
                android:background="@drawable/bg_attachment_widget_input"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="@dimen/attachment_widget_logo_size"
                    android:layout_height="@dimen/attachment_widget_logo_size"
                    android:alpha="0.62"
                    android:contentDescription="@string/app_brand"
                    android:scaleType="fitCenter"
                    android:src="@drawable/freechat_logo_white_transparent" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/main_panel_input"
                    android:textColor="#D0CED6"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:baselineAligned="false"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_attachment_widget_button"
                    android:contentDescription="@string/button_camera"
                    android:padding="11dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_camera_new"
                    android:tint="#FFFFFF" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_attachment_widget_button"
                    android:contentDescription="@string/content_desc_open_gallery"
                    android:padding="11dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_photo_new"
                    android:tint="#FFFFFF" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_attachment_widget_button"
                    android:contentDescription="@string/button_files"
                    android:padding="11dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_file_new"
                    android:tint="#FFFFFF" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_attachment_widget_button"
                    android:contentDescription="@string/content_desc_microphone"
                    android:padding="11dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_mic"
                    android:tint="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvWidgetTransparencyLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/widget_config_transparency_label"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWidgetTransparencyValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#8E8E93"
                android:textSize="14sp" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/widgetTransparencySeekBar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF"
            android:progressBackgroundTint="#333333" />

        <TextView
            android:id="@+id/tvWidgetTransparencyHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/widget_config_transparency_hint"
            android:textColor="#8E8E93"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
