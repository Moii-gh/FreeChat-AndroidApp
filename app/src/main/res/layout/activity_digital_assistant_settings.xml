<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingHorizontal="12dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_circle_outline"
                android:clickable="true"
                android:focusable="true"
                android:padding="6dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/digital_assistant_short_title"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/digitalAssistantSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/settings_profile_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvDigitalAssistantTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/digital_assistant_title"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDigitalAssistantDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/digital_assistant_description"
                android:textColor="#A8A8A8"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/digitalAssistantEnableRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="54dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvDigitalAssistantEnable"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/digital_assistant_enable"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchDigitalAssistant"
                    android:layout_width="50dp"
                    android:layout_height="30dp"
                    android:minWidth="50dp"
                    android:minHeight="30dp"
                    android:paddingHorizontal="3dp"
                    android:paddingVertical="2dp"
                    android:showText="false"
                    android:splitTrack="false"
                    android:textOff=""
                    android:textOn=""
                    android:thumb="@drawable/bg_adult_switch_thumb"
                    app:track="@drawable/bg_adult_switch_track"
                    app:useMaterialThemeColors="false" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvDigitalAssistantPermissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/digital_assistant_permissions_explanation"
                android:textColor="#8E8E93"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvDigitalAssistantStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/chip_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:textColor="#F2F2F2"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btnAssignDigitalAssistant"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/btn_ok_white_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/digital_assistant_assign_default"
                android:textColor="#202020"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnGrantDigitalAssistantPermissions"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_capsule_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/digital_assistant_grant_permissions"
                android:textColor="#F2F2F2"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
