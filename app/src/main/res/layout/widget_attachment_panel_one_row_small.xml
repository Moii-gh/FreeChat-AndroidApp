<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="@dimen/attachment_widget_root_padding"
    android:paddingTop="@dimen/attachment_widget_root_padding"
    android:paddingEnd="@dimen/attachment_widget_root_padding"
    android:paddingBottom="@dimen/attachment_widget_root_padding">

    <LinearLayout
        android:id="@+id/widgetPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_attachment_widget_one_row_panel_small"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/attachment_widget_one_row_small_padding">

        <ImageView
            android:id="@+id/widgetInput"
            android:layout_width="@dimen/attachment_widget_one_row_small_button_size"
            android:layout_height="@dimen/attachment_widget_one_row_small_button_size"
            android:background="@drawable/bg_attachment_widget_active_small"
            android:clickable="true"
            android:contentDescription="@string/attachment_widget_hint"
            android:focusable="true"
            android:padding="@dimen/attachment_widget_one_row_small_icon_padding"
            android:scaleType="fitCenter"
            android:src="@drawable/freechat_logo_white_transparent" />

        <ImageView
            android:id="@+id/widgetMic"
            android:layout_width="@dimen/attachment_widget_one_row_small_button_size"
            android:layout_height="@dimen/attachment_widget_one_row_small_button_size"
            android:layout_marginStart="@dimen/attachment_widget_one_row_small_button_gap"
            android:background="@drawable/bg_attachment_widget_one_row_button_small"
            android:contentDescription="@string/content_desc_microphone"
            android:padding="@dimen/attachment_widget_one_row_small_icon_padding"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_mic"
            android:tint="#FFFFFF" />
    </LinearLayout>
</LinearLayout>
