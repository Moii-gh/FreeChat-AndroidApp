<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_debug_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="18dp"
    android:paddingEnd="16dp"
    android:paddingBottom="22dp">

    <TextView
        android:layout_width="42dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_da_drag_handle" />

    <TextView
        android:id="@+id/tvLogsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/debug_logs_title"
        android:textColor="@color/security_text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvLogsEmpty"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:gravity="center"
        android:text="@string/debug_logs_empty"
        android:textColor="@color/security_text_muted"
        android:textSize="14sp" />

    <ScrollView
        android:id="@+id/logsScroll"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_debug_glass_panel"
        android:fillViewport="true"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvLogsContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/security_text_secondary"
            android:textIsSelectable="true"
            android:textSize="11sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCopyLogs"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_debug_primary_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/debug_logs_copy"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnClearLogs"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_debug_secondary_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/debug_logs_clear"
            android:textColor="@color/security_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
