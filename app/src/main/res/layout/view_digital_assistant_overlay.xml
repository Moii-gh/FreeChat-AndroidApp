<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/assistantOverlayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <View
        android:id="@+id/dimView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="#A6000000"
        android:clickable="true"
        android:focusable="false" />

    <LinearLayout
        android:id="@+id/actionsColumn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="6dp"
        android:alpha="0"
        android:clipChildren="false"
        android:elevation="18dp"
        android:orientation="vertical"
        android:translationY="14dp">

        <TextView
            android:id="@+id/openFreeChatButton"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:background="@drawable/bg_da_floating_chip"
            android:drawableStart="@drawable/ic_da_chip_open"
            android:drawablePadding="8dp"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:paddingStart="14dp"
            android:paddingEnd="16dp"
            android:text="@string/digital_assistant_open_freechat"
            android:textColor="#E6FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/translateScreenButton"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_da_floating_chip"
            android:drawableStart="@drawable/ic_da_chip_translate"
            android:drawablePadding="8dp"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:paddingStart="14dp"
            android:paddingEnd="16dp"
            android:text="@string/digital_assistant_translate_screen"
            android:textColor="#E6FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/askScreenButton"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_da_floating_chip"
            android:drawableStart="@drawable/ic_da_chip_ask"
            android:drawablePadding="8dp"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:paddingStart="14dp"
            android:paddingEnd="16dp"
            android:text="@string/digital_assistant_ask_screen"
            android:textColor="#E6FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="352dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:alpha="0"
        android:background="@drawable/bg_da_bottom_panel"
        android:clipChildren="true"
        android:clipToOutline="true"
        android:clipToPadding="true"
        android:elevation="24dp"
        android:scaleX="0.98"
        android:scaleY="0.98"
        android:translationY="52dp">

        <LinearLayout
            android:id="@+id/sheetContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:orientation="vertical">

            <View
                android:id="@+id/dragHandle"
                android:layout_width="34dp"
                android:layout_height="2dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="7dp"
                android:background="@drawable/bg_da_drag_handle" />

            <TextView
                android:id="@+id/assistantTitle"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_marginStart="28dp"
                android:layout_marginTop="13dp"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:singleLine="true"
                android:text="FreeChat | Ассистент"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp" />

            <FrameLayout
                android:id="@+id/messagesFrame"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:clipChildren="true"
                android:clipToPadding="true">

                <ScrollView
                    android:id="@+id/responseScroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:fillViewport="false"
                    android:overScrollMode="never"
                    android:scrollbarStyle="insideOverlay"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/responseContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipChildren="false"
                        android:orientation="vertical"
                        android:paddingStart="28dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="76dp" />
                </ScrollView>

                <View
                    android:id="@+id/inputFade"
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_da_message_fade"
                    android:clickable="false"
                    android:focusable="false" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/inputRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="17dp"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="14dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/addButton"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="7dp"
                    android:layout_marginBottom="1dp"
                    android:background="@drawable/bg_da_plus_button"
                    android:contentDescription="@string/content_desc_add_attachment"
                    android:padding="8dp"
                    android:src="@drawable/ic_plus"
                    android:tint="#A0A0A0" />

                <LinearLayout
                    android:id="@+id/inputCapsule"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_da_input_field"
                    android:minHeight="38dp"
                    android:orientation="vertical"
                    android:paddingStart="4dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="4dp"
                    android:paddingBottom="4dp">

                    <FrameLayout
                        android:id="@+id/previewContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="8dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:visibility="gone">

                        <FrameLayout
                            android:id="@+id/previewFrame"
                            android:layout_width="64dp"
                            android:layout_height="104dp"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <ImageView
                                android:id="@+id/previewImage"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_da_preview"
                                android:clipToOutline="true"
                                android:contentDescription="@string/digital_assistant_screen_analysis"
                                android:scaleType="centerCrop" />

                            <ImageButton
                                android:id="@+id/removePreview"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="top|end"
                                android:layout_marginTop="-7dp"
                                android:layout_marginEnd="-7dp"
                                android:background="@drawable/bg_da_preview_close"
                                android:contentDescription="@string/digital_assistant_close"
                                android:padding="3dp"
                                android:src="@drawable/ic_assistant_close"
                                android:tint="#FFFFFFFF" />
                        </FrameLayout>
                    </FrameLayout>

                    <LinearLayout
                        android:id="@+id/inputLine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="bottom"
                        android:minHeight="30dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/inputField"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_weight="1"
                            android:background="@null"
                            android:gravity="center_vertical"
                            android:hint="@string/main_panel_input"
                            android:imeOptions="actionSend"
                            android:includeFontPadding="false"
                            android:inputType="textCapSentences|textMultiLine"
                            android:maxLines="4"
                            android:minHeight="30dp"
                            android:minLines="1"
                            android:paddingStart="10dp"
                            android:paddingTop="5dp"
                            android:paddingEnd="8dp"
                            android:paddingBottom="5dp"
                            android:textColor="#F3F3F3"
                            android:textColorHint="#8E8E93"
                            android:textCursorDrawable="@null"
                            android:textSize="15sp" />

                        <ImageView
                            android:id="@+id/micIcon"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginEnd="3dp"
                            android:layout_marginBottom="0dp"
                            android:contentDescription="@null"
                            android:padding="6dp"
                            android:src="@drawable/ic_mic"
                            android:tint="#8E8E93" />

                        <ImageButton
                            android:id="@+id/sendButton"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="2.5dp"
                            android:layout_marginBottom="-1dp"
                            android:background="@drawable/bg_da_send_button"
                            android:contentDescription="@string/content_desc_send"
                            android:enabled="false"
                            android:padding="6dp"
                            android:src="@drawable/ic_send_arrow_up"
                            android:tint="#1B1B1B" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/attachmentMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:alpha="0"
        android:background="@drawable/bottom_sheet_bg"
        android:clipChildren="false"
        android:elevation="26dp"
        android:orientation="vertical"
        android:paddingBottom="30dp"
        android:translationY="180dp"
        android:visibility="gone">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="24dp"
            android:background="#3A3A3C" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:id="@+id/menuCameraButton"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:background="@drawable/top_button_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_camera_new"
                    android:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/menuCameraText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/button_camera"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <Space
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <LinearLayout
                android:id="@+id/menuPhotoButton"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:background="@drawable/top_button_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_photo_new"
                    android:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/menuPhotoText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/button_photo"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <Space
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <LinearLayout
                android:id="@+id/menuFilesButton"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:background="@drawable/top_button_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_file_new"
                    android:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/menuFilesText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/button_files"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/confirmPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_da_confirm_panel"
        android:clipChildren="false"
        android:elevation="24dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/confirmText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/digital_assistant_close_generating_message"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/cancelCloseButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_da_action_pill"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minWidth="96dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/button_cancel"
                android:textColor="#202020"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/confirmCloseButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_da_action_pill"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minWidth="96dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/digital_assistant_close"
                android:textColor="#202020"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
