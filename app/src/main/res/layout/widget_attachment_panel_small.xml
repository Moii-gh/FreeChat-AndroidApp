<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="@dimen/attachment_widget_root_padding"
    android:paddingTop="@dimen/attachment_widget_root_padding"
    android:paddingEnd="@dimen/attachment_widget_root_padding"
    android:paddingBottom="@dimen/attachment_widget_root_padding">

    <FrameLayout
        android:id="@+id/widgetPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_attachment_widget_panel_small"
        android:clipToOutline="true">

        <ImageView
            android:id="@+id/widgetBackgroundImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/widgetBackgroundScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="@dimen/attachment_widget_small_padding">

        <ImageView
            android:id="@+id/widgetMic"
            android:layout_width="@dimen/attachment_widget_small_button_size"
            android:layout_height="@dimen/attachment_widget_small_button_size"
            android:background="@drawable/bg_attachment_widget_button_small"
            android:contentDescription="@string/content_desc_microphone"
            android:padding="@dimen/attachment_widget_small_icon_padding"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_mic"
            android:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/widgetCamera"
            android:layout_width="@dimen/attachment_widget_small_button_size"
            android:layout_height="@dimen/attachment_widget_small_button_size"
            android:layout_marginStart="@dimen/attachment_widget_small_button_gap"
            android:background="@drawable/bg_attachment_widget_button_small"
            android:contentDescription="@string/button_camera"
            android:padding="@dimen/attachment_widget_small_icon_padding"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_camera_new"
            android:tint="#FFFFFF" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
