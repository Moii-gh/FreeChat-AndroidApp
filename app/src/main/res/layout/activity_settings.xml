<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══════ TOOLBAR ═══════ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingHorizontal="12dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:src="@drawable/ic_arrow_back"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_circle_outline"
                app:tint="#FFFFFF"/>

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </RelativeLayout>

        <!-- ═══════ PROFILE CARD ═══════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/settings_profile_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="28dp"
                android:paddingBottom="20dp">

            <!-- Avatar with edit icon -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <!-- Avatar circle -->
                <FrameLayout
                    android:id="@+id/flAvatar"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/avatar_settings_bg">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="44dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@android:color/transparent">
                        
                        <ImageView
                            android:id="@+id/ivAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tvAvatarLetter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:textColor="#CCCCCC"
                        android:textSize="40sp"
                        android:textStyle="bold"/>
                </FrameLayout>

                <!-- Edit status icon removed -->
            </FrameLayout>

            <!-- User name -->
            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"/>

            <!-- User email (underlined, link-style) -->
            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#9E9E9E"
                android:textSize="14sp"
                android:autoLink="email"
                android:linksClickable="false"
                android:textColorLink="#9E9E9E"/>

            <!-- Edit profile button (outline style) -->
            <TextView
                android:id="@+id/btnEditProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/btn_edit_profile_outline"
                android:paddingHorizontal="18dp"
                android:paddingVertical="8dp"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true"/>
            </LinearLayout>

            <!-- Logout button -->
            <ImageView
                android:id="@+id/btnLogout"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_logout"
                android:background="@drawable/bg_circle_outline"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"/>
        </FrameLayout>

        <!-- ═══════ SETTINGS HEADER ═══════ -->
        <TextView
            android:id="@+id/tvSettingsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="4dp"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <!-- ═══════ SETTINGS LIST ═══════ -->

        <!-- Персонализация -->
        <LinearLayout
            android:id="@+id/itemPersonalization"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_personalization"
                app:tint="#FFFFFF"/>

            <TextView
                android:id="@+id/tvLabelPersonalization"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- AI Provider -->
        <LinearLayout
            android:id="@+id/itemAiProvider"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_brain"
                app:tint="#FFFFFF"/>

            <TextView
                android:id="@+id/tvLabelAiProvider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvAiProviderValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#8E8E93"
                android:textSize="13sp"/>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_chevron_right"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/itemAdultMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent">

            <TextView
                android:id="@+id/tvAdultModeBadge"
                android:layout_width="34dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_adult_badge"
                android:gravity="center"
                android:text="@string/adult_badge"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvLabelAdultMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/adult_mode_title"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvAdultModeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="@string/adult_replies_title"
                    android:textColor="#8E8E93"
                    android:textSize="12sp"/>
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAdultMode"
                android:layout_width="50dp"
                android:layout_height="30dp"
                android:minWidth="50dp"
                android:minHeight="30dp"
                android:paddingHorizontal="3dp"
                android:paddingVertical="2dp"
                android:showText="false"
                android:splitTrack="false"
                android:textOff=""
                android:textOn=""
                android:thumb="@drawable/bg_adult_switch_thumb"
                app:track="@drawable/bg_adult_switch_track"
                app:useMaterialThemeColors="false"/>
        </LinearLayout>

        <!-- Ссылки -->
        <LinearLayout
            android:id="@+id/itemLinks"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_link"
                app:tint="#FFFFFF"/>

            <TextView
                android:id="@+id/tvLabelLinks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- Язык -->
        <LinearLayout
            android:id="@+id/itemLanguage"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_language"
                app:tint="#FFFFFF"/>

            <TextView
                android:id="@+id/tvLabelLanguage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- Безопасность -->
        <LinearLayout
            android:id="@+id/itemSecurity"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_security"
                app:tint="#FFFFFF"/>

            <TextView
                android:id="@+id/tvLabelSecurity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/itemAbout"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_info"
                app:tint="#FFFFFF"/>

            <TextView
                android:id="@+id/tvLabelAbout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right"/>
        </LinearLayout>

        <!-- Сообщить о проблеме -->
        <LinearLayout
            android:id="@+id/itemReport"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_report"
                app:tint="#FFFFFF"/>

            <TextView
                android:id="@+id/tvLabelReport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- SPACER (pushes footer to bottom) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- ═══════ FOOTER ═══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/logo"/>

            <TextView
                android:id="@+id/tvAppVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#8E8E93"
                android:textSize="12sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
