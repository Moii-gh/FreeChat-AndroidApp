<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false"
    tools:context=".MainActivity">

    <!-- ОСНОВНОЙ КОНТЕНТ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:elevation="24dp"
            android:translationZ="24dp"
            android:padding="12dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/circle_button_bg"
                android:src="@drawable/ic_menu"
                android:padding="12dp"
                app:tint="#FFFFFF"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <!-- START LIMITS BUTTON -->
            <LinearLayout
                android:id="@+id/btnAddLimits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="44dp"
                android:orientation="vertical"
                android:background="@drawable/bg_purple_pill"
                android:foreground="@drawable/bg_purple_pill_ripple"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:paddingVertical="4dp"
                android:elevation="4dp"
                android:stateListAnimator="@null"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/tvAppName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FreeChat"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="normal"
                    android:includeFontPadding="false"/>

                <TextView
                    android:id="@+id/tvLimitsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#8E8E93"
                    android:textSize="11sp"
                    android:textStyle="normal"
                    android:includeFontPadding="false"
                    tools:text="Запросы: 20 + 5"/>
            </LinearLayout>
            <!-- END LIMITS BUTTON -->

            <FrameLayout
                android:id="@+id/topRightMain"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:visibility="visible"
                android:background="@drawable/circle_button_bg"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                    android:id="@+id/btnChat"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_anonymous_chat"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="#FFFFFF"/>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/topRightChat"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:background="@drawable/pill_button_bg"
                android:gravity="center_vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingHorizontal="4dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                    android:id="@+id/btnNewChat"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_new_chat"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="#FFFFFF"/>

                <ImageButton
                    android:id="@+id/btnMore"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_more_vertical"
                    android:padding="8dp"
                    app:tint="#FFFFFF"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- НАЧАЛЬНЫЙ ЭКРАН -->
        <LinearLayout
            android:id="@+id/welcomeScreen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintBottom_toTopOf="@id/bottomInputArea"
            app:layout_constraintVertical_chainStyle="packed">

            <TextView
                android:id="@+id/tvWelcomeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp"/>

            <LinearLayout
                android:id="@+id/btnCreateImage"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="@drawable/welcome_button_bg"
                android:paddingHorizontal="24dp"
                android:gravity="center"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_image"/>

                <TextView
                    android:id="@+id/tvBtnCreateImage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#B3B3B3"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout
                    android:id="@+id/btnIdea"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:background="@drawable/welcome_button_bg"
                    android:paddingHorizontal="24dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_idea"/>

                    <TextView
                        android:id="@+id/tvBtnIdea"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#B3B3B3"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnCenterMore"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:background="@drawable/welcome_button_bg"
                    android:paddingHorizontal="16dp"
                    android:gravity="center"
                    android:layout_marginStart="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tvBtnMore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#B3B3B3"
                        android:textSize="15sp"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
            </LinearLayout>

        <!-- ЭКРАН АНОНИМНОГО ЧАТА -->
        <LinearLayout
            android:id="@+id/anonymousWelcomeScreen"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintBottom_toTopOf="@id/bottomInputArea"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvAnonymousDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Этот чат не будет отображаться в вашей истории переписки и будет стерт после перезахода в приложение"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:alpha="0.7"/>

        </LinearLayout>

        <!-- КОНТЕЙНЕР СООБЩЕНИЙ -->
        <ScrollView
            android:id="@+id/messagesScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:id="@+id/messagesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </ScrollView>

        <View
            android:id="@+id/bottomInputScrim"
            android:layout_width="0dp"
            android:layout_height="170dp"
            android:background="@drawable/bottom_input_scrim"
            android:importantForAccessibility="no"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ScrollView
            android:id="@+id/suggestionsContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:clipToPadding="false"
            android:elevation="8dp"
            android:fillViewport="false"
            android:overScrollMode="never"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/bottomInputArea"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/welcomeScreen">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <TextView
                android:id="@+id/suggestionsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="РџРѕРїСѓР»СЏСЂРЅС‹Рµ РЅРѕРІРѕСЃС‚Рё" />

            <LinearLayout
                android:id="@+id/suggestionsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
            </LinearLayout>
        </ScrollView>

        <!-- НИЖНЯЯ ПАНЕЛЬ ВВОДА -->
        <LinearLayout
            android:id="@+id/bottomInputArea"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="vertical"
            android:paddingHorizontal="4dp"
            android:paddingVertical="6dp"
            android:background="@android:color/transparent"
            android:elevation="24dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:id="@+id/suggestionsContainerLegacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/suggestionsTitleLegacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="Популярные новости" />

                <LinearLayout
                    android:id="@+id/suggestionsListLegacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bottomInputRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="bottom"
                android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnPlus"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/circle_button_bg"
                android:src="@drawable/ic_plus"
                android:padding="8dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="4dp"
                app:tint="#8E8E93"/>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/editMessageBanner"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_gravity="top|center_horizontal"
                    android:background="@drawable/edit_message_banner_bg"
                    android:elevation="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="8dp"
                    android:translationZ="8dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:src="@drawable/ic_pen"
                        app:tint="#F2F2F7" />

                    <TextView
                        android:id="@+id/tvEditMessageTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="16dp"
                        android:text="Редактировать сообщение"
                        android:textColor="#F2F2F7"
                        android:textSize="12sp" />

                    <ImageView
                        android:id="@+id/btnCloseEditMessage"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/edit_message_close_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="4dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="#F2F2F7" />
                </LinearLayout>

            <LinearLayout
                android:id="@+id/inputCapsule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:orientation="vertical"
                android:background="@drawable/input_capsule_bg"
                android:paddingHorizontal="4dp"
                android:paddingVertical="4dp">

                <!-- Контейнер для превью -->
                <FrameLayout
                    android:id="@+id/previewContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone">

                    <!-- To ensure rounding is applied: clipToOutline=true -->
                    <ImageView
                        android:id="@+id/previewImage"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:background="@drawable/preview_background"
                        android:clipToOutline="true" />

                    <LinearLayout
                        android:id="@+id/previewFileContainer"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/preview_background"
                        android:visibility="gone"
                        android:padding="16dp"
                        android:clipToOutline="true">

                        <ImageView
                            android:id="@+id/previewFileIcon"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_file_new"
                            app:tint="#8E8E93"/>

                        <TextView
                            android:id="@+id/previewFileName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_marginTop="8dp"
                            android:maxLines="2"
                            android:ellipsize="end"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/btnRemovePreview"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="6dp"
                        android:background="@drawable/circle_button_bg"
                        android:padding="4dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="#FFFFFF"
                        android:clickable="true"
                        android:focusable="true"/>
                </FrameLayout>

                <!-- Контейнер для чипа -->
                <LinearLayout
                    android:id="@+id/contextChipContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/chip_background"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:id="@+id/chipIcon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_book_new"
                        app:tint="#FFFFFF"/>

                    <TextView
                        android:id="@+id/chipTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"/>

                    <ImageView
                        android:id="@+id/btnCloseChip"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="#8E8E93"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="32dp"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_gravity="center_vertical">
                        
                        <EditText
                            android:id="@+id/etInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="32dp"
                            android:background="@android:color/transparent"
                            android:textColorHint="#8E8E93"
                            android:textColor="#FFFFFF"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:textSize="15sp"
                            android:inputType="textMultiLine|textCapSentences"
                            android:textColorHighlight="#4D808080"
                            android:maxLines="5"
                            android:imeOptions="actionSend"/>

                        <LinearLayout
                            android:id="@+id/waveformContainer"
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:visibility="gone"
                            android:paddingHorizontal="10dp" />
                    </FrameLayout>

                    <ImageButton
                        android:id="@+id/btnMic"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_mic"
                        android:padding="6dp"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="2dp"
                        app:tint="#8E8E93"/>

                    <ImageButton
                        android:id="@+id/btnSend"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_solid_grey_bg"
                        android:src="@drawable/ic_send_arrow_up"
                        android:padding="6dp"
                        android:layout_marginBottom="2dp"
                        app:tint="#1C1C1E"/>
                </LinearLayout>

            </LinearLayout>
            </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- БОКОВОЕ МЕНЮ (DRAWER) ИЗ ОТДЕЛЬНОГО ФАЙЛА -->
    <include
        layout="@layout/drawer_chat_history"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="start" />
</androidx.drawerlayout.widget.DrawerLayout>
