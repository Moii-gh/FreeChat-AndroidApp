<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/security_surface_pressed" />
            <stroke
                android:width="1dp"
                android:color="@color/security_stroke_soft" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/security_surface_high" />
            <stroke
                android:width="1dp"
                android:color="@color/security_stroke" />
        </shape>
    </item>
</selector>
